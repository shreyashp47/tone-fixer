{
  "manifest_version": 3,
  "name": "Tone Fixer",
  "version": "1.0.0",
  "description": "Rewrite text in Polite, Casual, or Formal tone using AI. Supports Groq, Claude, ChatGPT, Gemini & Grok.",
  "homepage_url": "https://github.com/shreyashp47/tone-fixer",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [{
    "resources": ["guide.html"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
